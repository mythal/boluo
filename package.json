{
  "name": "boluo",
  "devDependencies": {
    "prettier": "^3.9.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "turbo": "^2.10.4",
    "typescript": "^6"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "optionalDependencies": {
    "syncpack": "^15.3.2"
  },
  "packageManager": "npm@10.9.2",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build:deploy": "turbo build --filter=legacy --filter=site --filter=spa",
    "build:legacy": "turbo build --filter=legacy",
    "build:site": "turbo build --filter=site",
    "build:spa": "turbo build --filter=spa",
    "build:storybook": "turbo build --filter=boluo-storybook",
    "check": "turbo run check --ui=stream --log-prefix=none --output-logs=new-only --continue=always",
    "dev": "turbo run dev",
    "dev:legacy": "turbo run dev --filter=legacy",
    "dev:site": "turbo run dev --filter=site",
    "dev:spa": "turbo run dev --filter=spa",
    "fix:versions": "syncpack fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "format:versions": "syncpack format",
    "generate": "turbo run generate",
    "lint": "turbo run lint --ui=stream --log-prefix=none --output-logs=full --continue=always",
    "lint:fix": "turbo run lint -- --fix",
    "lint:versions": "syncpack lint",
    "storybook": "turbo storybook",
    "test": "turbo run test"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
