{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "noUpdateNotifier": true,
  "globalEnv": ["NODE_ENV"],
  "tasks": {
    "generate": { "dependsOn": ["^generate"], "inputs": ["$TURBO_DEFAULT$"] },
    "build": {
      "dependsOn": ["^generate"],
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": ["dist/**"]
    },
    "lang-sources": {
      "dependsOn": ["^lang-sources"],
      "description": "Tracks i18n source changes through the site/spa dependency graph so @boluo/lang#generate follows newly added shared packages without repeating package globs here.",
      "inputs": ["$TURBO_DEFAULT$"]
    },
    "lint": { "dependsOn": ["@boluo/icons#generate"] },
    "test": { "dependsOn": ["check"] },
    "check": { "dependsOn": ["@boluo/icons#generate"] },
    "storybook": {
      "dependsOn": ["^generate"],
      "cache": false,
      "persistent": true,
      "interruptible": true
    },
    "dev": {
      "dependsOn": ["^generate"],
      "cache": false,
      "persistent": true,
      "interruptible": true,
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env",
        ".env.local",
        "$TURBO_ROOT$/.env",
        "$TURBO_ROOT$/.env.local"
      ],
      "env": ["ANALYZE", "BACKEND_URL"]
    },
    "spa#build": {
      "dependsOn": ["^generate", "@boluo/backend-proxy#build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env",
        ".env.local",
        "$TURBO_ROOT$/.env",
        "$TURBO_ROOT$/.env.local"
      ],
      "env": ["ANALYZE", "BACKEND_URL"],
      "outputs": ["out/**", ".next/**", "!.next/cache/**"]
    },
    "site#build": {
      "dependsOn": ["^generate"],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env",
        ".env.local",
        "$TURBO_ROOT$/.env",
        "$TURBO_ROOT$/.env.local"
      ],
      "env": ["ANALYZE", "BACKEND_URL"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "legacy#build": {
      "dependsOn": ["@boluo/backend-proxy#build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env",
        ".env.local",
        "$TURBO_ROOT$/.env",
        "$TURBO_ROOT$/.env.local"
      ],
      "outputs": ["dist/**"]
    },
    "boluo-storybook#build": {
      "dependsOn": ["^generate"],
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": ["storybook-static/**"]
    },
    "@boluo/lang#generate": {
      "dependsOn": ["site#lang-sources", "spa#lang-sources"],
      "outputs": ["src/en.json", "dist/**"]
    },
    "@boluo/icons#generate": {
      "inputs": ["icons/**", "svgr.config.js", "package.json"],
      "outputs": ["src/**"]
    }
  }
}
