  "query": "SELECT\n    member AS \"member!: ChannelMember\"\nFROM\n    channel_members member\n    INNER JOIN channels channel ON channel.id = member.channel_id\nWHERE\n    channel.space_id = $1\n    AND channel.deleted = FALSE\n    AND member.is_joined = TRUE;\n",
